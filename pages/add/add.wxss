.container {
  padding: 20rpx;
  padding-bottom: 120rpx; /* 给底部导航留空间 */
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}
.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

/* 分类 */
.cate-list {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.cate-item {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
}
.cate-item.active {
  background: #2ecc71;
  color: #fff;
}
.icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 10rpx;
}

/* 输入 */
.input-group {
  margin-bottom: 30rpx;
}
.input {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
}
.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 快速 */
.quick-group {
  margin-bottom: 40rpx;
}
.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}
.quick-item {
  padding: 15rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
}

/* 按钮 */
.save-btn {
  background: #2ecc71;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 20rpx;
}

/* 底部自定义导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #eee;
  z-index: 999;
}
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 24rpx;
}
.tab-item.active {
  color: #2ecc71;
}
.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
.tab-text {
  font-size: 20rpx;
}