.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}
.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}
.cate-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 34rpx;
}
.cate-item {
  min-height: 112rpx;
  padding: 16rpx 8rpx;
  background: #f5f7f8;
  border-radius: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333;
}
.cate-item.active {
  background: #2ecc71;
  color: #fff;
}
.icon {
  font-size: 38rpx;
  display: block;
  margin-bottom: 8rpx;
}
.input-group {
  margin-bottom: 28rpx;
}
.input {
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
}
.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
  line-height: 1.5;
}
.quick-group {
  margin-bottom: 40rpx;
}
.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}
.quick-item {
  padding: 14rpx 18rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
}
.save-btn {
  background: #2ecc71;
  border-radius: 16rpx;
  font-size: 30rpx;
}
