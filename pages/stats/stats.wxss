.time-tabs {
  display: flex;
  justify-content: space-around;
}
.time-tab {
  padding: 15rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #666;
}
.time-tab.active {
  background: #2ecc71;
  color: #fff;
}
.overview-row {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}
.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.overview-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #2ecc71;
}
.overview-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.equal-card {
  background: linear-gradient(135deg, #e8f8f0, #d4efdf);
}
.equal-list {
  margin-top: 15rpx;
}
.equal-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.equal-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}
.equal-text {
  font-size: 26rpx;
  color: #555;
}
.chart-area {
  margin-top: 20rpx;
  padding: 10rpx 0;
}
.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
}
.chart-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.chart-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 250rpx;
}
.chart-bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s ease;
}
.chart-value {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 6rpx;
}
.chart-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}
.category-bars {
  margin-top: 20rpx;
}
.cate-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.cate-label {
  font-size: 26rpx;
  width: 130rpx;
}
.cate-bar-bg {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  margin: 0 15rpx;
  overflow: hidden;
}
.cate-bar {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s ease;
}
.cate-percent {
  font-size: 26rpx;
  font-weight: bold;
  width: 90rpx;
  text-align: right;
}
.advice-card {
  background: linear-gradient(135deg, #fff9e6, #fff3cd);
}
.advice-list {
  margin-top: 15rpx;
}
.advice-item {
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #555;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.advice-item:last-child {
  border-bottom: none;
}