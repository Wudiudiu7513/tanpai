.user-card {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
}
.user-row {
  display: flex;
  align-items: center;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  margin-right: 30rpx;
  border: 4rpx solid #2ecc71;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-edit {
  position: absolute;
  right: 0;
  bottom: 0;
  background: #2ecc71;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx;
  border-radius: 50%;
}
.user-info {
  flex: 1;
}
.user-name-input {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.user-level {
  font-size: 24rpx;
  color: #2ecc71;
  padding: 6rpx 16rpx;
  background: rgba(46,204,113,0.1);
  border-radius: 20rpx;
}
.level-progress {
  margin-top: 20rpx;
}
.level-bar-bg {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
}
.level-bar {
  height: 100%;
  background: #2ecc71;
  transition: width 0.5s;
}
.level-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.data-item {
  text-align: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}
.data-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #2ecc71;
  display: block;
}
.data-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.tree-card {
  text-align: center;
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
}
.tree-area {
  padding: 20rpx 0;
}
.tree-emoji {
  font-size: 80rpx;
  display: block;
}
.tree-status {
  font-size: 28rpx;
  color: #333;
  margin-top: 10rpx;
}
.tree-info {
  font-size: 24rpx;
  color: #666;
}
.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}
.badge-item {
  text-align: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}
.badge-item.locked {
  opacity: 0.4;
}
.badge-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 6rpx;
}
.badge-name {
  font-size: 22rpx;
  font-weight: bold;
}
.badge-desc {
  font-size: 18rpx;
  color: #999;
}
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 15rpx;
}
.calendar-weekdays {
  display: flex;
  justify-content: space-around;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}
.calendar-days {
  display: flex;
  flex-wrap: wrap;
}
.calendar-day {
  width: 14.28%;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  position: relative;
}
.calendar-day.empty {
  color: #eee;
}
.calendar-day.today {
  color: #2ecc71;
  font-weight: bold;
}
.calendar-day.checked {
  color: #2ecc71;
}
.check-dot {
  width: 12rpx;
  height: 12rpx;
  background: #2ecc71;
  border-radius: 50%;
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
}
.goal-setting {
  padding: 10rpx 0;
}
.goal-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-arrow {
  color: #999;
  font-size: 32rpx;
}